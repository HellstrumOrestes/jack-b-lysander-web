---
// Tarjeta sencilla de una obra para listados.
import type { CollectionEntry } from 'astro:content';
interface Props {
  obra: CollectionEntry<'obras'>;
}
const { obra } = Astro.props;
---

<article class="obra-card">
  <h3>
    <a href={`/obras/${obra.slug}/`}>{obra.data.titulo}</a>
  </h3>
  <p class="meta">
    {obra.data.genero ? `${obra.data.genero} · ` : ''}{obra.data.estado}
  </p>
  <p class="sinopsis">{obra.data.sinopsis_corta}</p>
</article>

<style>
  .obra-card {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .obra-card:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .obra-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.4rem;
    font-weight: 600;
  }
  .obra-card h3 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .obra-card h3 a:hover {
    color: var(--color-accent);
  }
  .obra-card .meta {
    margin: 0 0 0.4rem;
  }
  .obra-card .sinopsis {
    margin: 0;
    color: var(--color-text-soft);
  }
</style>
