---
import Fleuron from './Fleuron.astro';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <Fleuron size={14} opacity={0.35} />
    <p class="footer-line">
      <span>Jack B. Lysander</span>
      <span class="dot">·</span>
      <span>Ficción serializada en español</span>
    </p>
    <p class="footer-meta">
      <a href="/rss.xml">RSS</a>
      <span class="dot">·</span>
      <a href="/newsletter">Newsletter</a>
      <span class="dot">·</span>
      <span>© {year}</span>
    </p>
  </div>
</footer>
