---
// Pie de página minimalista
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p>
      <a href="/sobre/">Sobre el autor</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="/rss.xml">RSS</a>
    </p>
    <p class="copy">&copy; {year} Jack B. Lysander</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xl);
    padding: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-soft);
  }
  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-inner p { margin: 0.25rem 0; }
  .footer-inner a { color: var(--color-text-soft); }
  .footer-inner a:hover { color: var(--color-accent); }
  .sep { margin: 0 0.5rem; }
  .copy { font-size: 0.8rem; }
</style>
