---
// Tarjeta-formulario para suscripción a la newsletter de Buttondown.
// Sin JavaScript propio, sin claves API. Buttondown gestiona el
// double opt-in del lado servidor.
//
// Username de Buttondown: jack_b_lysander
// Endpoint público:
//   https://buttondown.com/api/emails/embed-subscribe/jack_b_lysander
//
// Props:
//   - compact: variante reducida para final de capítulo / sidebars.
//   - title: titular personalizable.
//   - description: subtexto personalizable.

interface Props {
  compact?: boolean;
  title?: string;
  description?: string;
}

const {
  compact = false,
  title = compact
    ? 'Recibe el próximo capítulo'
    : 'El próximo capítulo, en tu correo',
  description = 'Aviso por email cuando publico un capítulo nuevo. Sin spam, sin promociones, sin tracking. Solo capítulos.',
} = Astro.props;

const ENDPOINT =
  'https://buttondown.com/api/emails/embed-subscribe/jack_b_lysander';
const POPUP = 'https://buttondown.com/jack_b_lysander';
---

<form
  action={ENDPOINT}
  method="post"
  target="popupwindow"
  onsubmit={`window.open('${POPUP}', 'popupwindow')`}
  class={`newsletter-card ${compact ? 'is-compact' : ''}`}
>
  <div class="newsletter-card-body">
    <p class="newsletter-card-kicker">— Newsletter —</p>
    <label class="newsletter-card-title" for="bd-email">{title}</label>
    {!compact && <p class="newsletter-card-desc">{description}</p>}
  </div>
  <div class="newsletter-card-form">
    <input
      type="email"
      name="email"
      id="bd-email"
      placeholder="tu@email.com"
      required
      autocomplete="email"
      aria-label="Tu correo electrónico"
    />
    <button type="submit">Suscribirme</button>
  </div>
</form>

<style>
  .newsletter-card {
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.6rem 1.6rem 1.4rem;
    margin: var(--space-lg) auto;
    max-width: var(--measure);
    font-family: var(--sans);
  }
  .newsletter-card.is-compact {
    padding: 1.2rem 1.3rem 1.1rem;
  }
  .newsletter-card-body {
    margin-bottom: 1rem;
  }
  .newsletter-card-kicker {
    font-family: var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin: 0 0 0.4rem;
  }
  .newsletter-card-title {
    display: block;
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.3rem;
    line-height: 1.25;
  }
  .newsletter-card.is-compact .newsletter-card-title {
    font-size: 1.15rem;
  }
  .newsletter-card-desc {
    margin: 0;
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .newsletter-card-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .newsletter-card input[type='email'] {
    flex: 1 1 220px;
    min-width: 0;
    font-family: var(--sans);
    font-size: 1rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--rule);
    background: var(--bg);
    color: var(--ink);
    border-radius: 4px;
  }
  .newsletter-card input[type='email']:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }
  .newsletter-card input[type='email']::placeholder {
    color: var(--ink-faint);
  }
  .newsletter-card button {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    padding: 0.65rem 1.2rem;
    background: var(--accent);
    color: var(--paper);
    border: 1px solid var(--accent);
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .newsletter-card button:hover {
    background: var(--accent-2);
    border-color: var(--accent-2);
  }
  @media (max-width: 480px) {
    .newsletter-card-form {
      flex-direction: column;
      align-items: stretch;
    }
    .newsletter-card input[type='email'] {
      flex: 0 0 auto;
      width: 100%;
    }
    .newsletter-card button {
      width: 100%;
    }
  }
</style>
