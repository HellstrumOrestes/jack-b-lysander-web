---
// Layout base: HTML, head con SEO, header, slot, footer.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  /** Si true, no añade el sufijo " — Jack B. Lysander" al título. */
  rawTitle?: boolean;
  /** Ruta absoluta o URL completa de la imagen Open Graph (1200×630). */
  ogImage?: string;
  /** Tipo Open Graph: 'website' por defecto, 'article' para capítulos. */
  type?: 'website' | 'article';
  /** ISO 8601 de la fecha de publicación (solo para articles). */
  publishedTime?: string;
  /** ISO 8601 de última modificación. */
  modifiedTime?: string;
  /** Array de objetos JSON-LD adicionales (Person, Chapter, etc.). */
  schema?: Record<string, unknown>[];
  /** Si true, el contenedor principal usa un ancho mayor (ideal para
   *  páginas de listado en grid, no para lectura larga). */
  wide?: boolean;
}

const {
  title,
  description = 'Ficción serializada en español por Jack B. Lysander.',
  rawTitle = false,
  ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  schema,
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#faf7f2" />

    <!-- Favicons. SVG con prioridad para navegadores modernos.
         logo-transparent.png como fallback / apple-touch-icon. Sustituye
         los archivos en public/ cuando tengas la imagen de marca real. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/logo-transparent.png" />
    <link rel="apple-touch-icon" href="/logo-transparent.png" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Jack B. Lysander"
      href="/rss.xml"
    />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- SEO meta + JSON-LD -->
    <SEO
      title={title}
      description={description}
      rawTitle={rawTitle}
      ogImage={ogImage}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      schema={schema}
    />
  </head>
  <body>
    <div class="site-wrapper">
      <Header />
      <main class={wide ? 'wide' : undefined}>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
