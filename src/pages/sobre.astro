---
// Página "Sobre mí". Carga el contenido desde src/sobre.md.
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterCard from '../components/NewsletterCard.astro';
import Fleuron from '../components/Fleuron.astro';

let Content: any = null;
let frontmatter: any = {};
try {
  const mod: any = await import('../sobre.md');
  Content = mod.Content;
  frontmatter = mod.frontmatter ?? {};
} catch {
  // Si no existe el archivo, mostramos placeholder.
}

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jack B. Lysander',
  description: frontmatter.descripcion ?? 'Autor de ficción serializada en español.',
  url: new URL('/sobre/', Astro.site).toString(),
  inLanguage: 'es-ES',
};
---

<BaseLayout
  title={frontmatter.titulo ?? 'Sobre mí'}
  description={frontmatter.descripcion ?? 'Sobre Jack B. Lysander.'}
  schema={[personSchema]}
  active="sobre"
>
  <article class="sobre">
    <header class="head">
      <p class="kicker">Sobre</p>
      <h1>{frontmatter.titulo ?? 'Sobre mí'}</h1>
      <div class="orn"><Fleuron size={14} opacity={0.5} /></div>
    </header>

    <div class="prose">
      {Content ? <Content /> : (
        <p class="text-soft">
          (Falta el archivo <code>src/sobre.md</code>.)
        </p>
      )}
    </div>
  </article>

  <NewsletterCard compact />
</BaseLayout>

<style>
  .head {
    text-align: center;
    margin: 1.5rem auto 2.5rem;
    max-width: var(--measure);
  }
  .kicker {
    font-family: var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin: 0 0 0.4rem;
  }
  .head h1 {
    font-family: var(--display);
    font-size: 2.4rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.1;
  }
  .orn {
    color: var(--ink-faint);
    margin-top: 0.6rem;
  }
</style>
