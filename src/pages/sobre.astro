---
// Página "Sobre el autor". Carga el contenido desde src/content/sobre.md
// (un único archivo Markdown). Si no existe, muestra placeholder.
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

// Importación directa del Markdown como módulo Astro
let Content: any = null;
let frontmatter: any = {};
try {
  const mod: any = await import('../sobre.md');
  Content = mod.Content;
  frontmatter = mod.frontmatter ?? {};
} catch {
  // si no existe el archivo, dejamos los defaults
}

// JSON-LD Person: identifica al autor para que motores y LLMs
// asocien correctamente las obras y la página.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jack B. Lysander',
  alternateName: 'Jack B. Lysander',
  description: frontmatter.descripcion ?? 'Autor de ficción serializada en español.',
  url: new URL('/sobre/', Astro.site).toString(),
  inLanguage: 'es-ES',
};
---

<BaseLayout
  title={frontmatter.titulo ?? 'Sobre mí'}
  description={frontmatter.descripcion ?? 'Sobre Jack B. Lysander.'}
  schema={[personSchema]}
>
  <article class="prose sobre">
    <h1>{frontmatter.titulo ?? 'Sobre mí'}</h1>
    {Content ? <Content /> : (
      <p class="text-soft">
        (Falta el archivo <code>src/content/sobre.md</code>.)
      </p>
    )}
  </article>

  <NewsletterForm compact />
</BaseLayout>

<style>
  .sobre h1 {
    text-align: center;
    margin-bottom: var(--space-md);
  }
</style>
