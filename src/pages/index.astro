---
import BaseLayout from '../layouts/BaseLayout.astro';
import Bookshelf from '../components/Bookshelf.astro';
import NewsletterCard from '../components/NewsletterCard.astro';
import Fleuron from '../components/Fleuron.astro';
import { getCollection } from 'astro:content';

const obras = (await getCollection('obras'))
  .sort((a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0));
---
<BaseLayout active="home">
  <main class="view view-home">
    <section class="hero">
      <p class="hero-kicker">
        <span class="rule" /> Ficción serializada en español <span class="rule" />
      </p>
      <h1 class="hero-name">
        <span class="hero-first">Jack B.</span>
        <span class="hero-last">Lysander</span>
      </h1>
      <p class="hero-bio">
        Aquí publico ficción capítulo a capítulo, sin prisa y sin ruido.
        Si te gusta lo que lees, suscríbete a la newsletter para recibir
        cada nuevo capítulo en tu correo.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href="/newsletter">Suscribirme</a>
      </div>
    </section>

    <div class="ornament"><Fleuron size={18} opacity={0.5} /></div>

    <section class="obras-section">
      <header class="section-head">
        <p class="section-kicker">Obras</p>
        <h2 class="section-title">La estantería</h2>
        <p class="section-desc">
          Pasa el ratón por un lomo para ver de qué va. Click para entrar.
        </p>
      </header>
      <Bookshelf obras={obras} />
    </section>

    <div class="ornament"><Fleuron size={14} opacity={0.4} /></div>

    <section class="newsletter-block">
      <NewsletterCard />
    </section>
  </main>
</BaseLayout>
