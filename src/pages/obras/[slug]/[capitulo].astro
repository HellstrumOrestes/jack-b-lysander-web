---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Fleuron from '../../../components/Fleuron.astro';
import ReadingProgress from '../../../components/ReadingProgress.astro';
import GlosarioPin from '../../../components/GlosarioPin.astro';
import ProseParagraph from '../../../components/ProseParagraph.astro';
import NewsletterCard from '../../../components/NewsletterCard.astro';
import { getCollection, getEntry } from 'astro:content';
import { toRoman } from '../../../lib/utils';

export async function getStaticPaths() {
  const caps = await getCollection('capitulos');
  return caps.map((c) => {
    const slugFile = c.slug.split('/').pop();
    return {
      params: { slug: c.data.obra, capitulo: slugFile },
      props: { capitulo: c },
    };
  });
}

const { capitulo } = Astro.props;
const obra = await getEntry('obras', capitulo.data.obra);
const siblings = (await getCollection('capitulos', (c) => c.data.obra === capitulo.data.obra))
  .sort((a, b) => a.data.numero - b.data.numero);
const idx = siblings.findIndex((c) => c.id === capitulo.id);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;

const slugOf = (c: typeof capitulo) => c.slug.split('/').pop();
const hrefOf = (c: typeof capitulo) => `/obras/${c.data.obra}/${slugOf(c)}/`;

// Convertir el cuerpo markdown a párrafos planos para usar ProseParagraph,
// que soporta los marcadores {término:slug}.
const raw = capitulo.body.trim();
const parrafos = raw
  .split(/\n{2,}/)
  .map((p) => p.replace(/\n/g, ' ').trim())
  .filter(Boolean);
---
<BaseLayout active="home"
            title={`${capitulo.data.titulo} — ${obra?.data.titulo} — Jack B. Lysander`}
            description={capitulo.data.sinopsis}>
  <ReadingProgress target=".capitulo" />
  <main class="view view-capitulo">
    <nav class="breadcrumb">
      <a href="/">Obras</a>
      <span class="sep">/</span>
      <a href={`/obras/${capitulo.data.obra}/`}>{obra?.data.titulo}</a>
    </nav>

    <article class="capitulo">
      <header class="capitulo-header">
        <p class="capitulo-header-kicker">
          {obra?.data.titulo} <span class="dot">·</span> Capítulo {toRoman(capitulo.data.numero)}
        </p>
        <h1 class="capitulo-header-title">{capitulo.data.titulo}</h1>
        <p class="capitulo-header-meta">
          <span>{capitulo.data.fecha}</span>
          <span class="dot">·</span>
          <span>{capitulo.data.minutos} min de lectura</span>
        </p>
        <div class="capitulo-header-orn"><Fleuron size={14} opacity={0.5} /></div>
      </header>

      <div class="prose">
        {parrafos.map((p) => <ProseParagraph text={p} />)}
        <div class="prose-end"><Fleuron size={14} opacity={0.45} /></div>
      </div>
    </article>

    <nav class="capitulo-nav" aria-label="Navegación entre capítulos">
      <div class="capitulo-nav-grid">
        {prev ? (
          <a class="capitulo-nav-prev" href={hrefOf(prev)}>
            <span class="capitulo-nav-label">← Capítulo {toRoman(prev.data.numero)}</span>
            <span class="capitulo-nav-title">{prev.data.titulo}</span>
          </a>
        ) : <span />}
        <a class="capitulo-nav-index" href={`/obras/${capitulo.data.obra}/`}>Índice</a>
        {next ? (
          <a class={`capitulo-nav-next ${next.data.proximo ? 'is-disabled' : ''}`}
             href={next.data.proximo ? '#' : hrefOf(next)}
             aria-disabled={next.data.proximo ? 'true' : 'false'}>
            <span class="capitulo-nav-label">
              {next.data.proximo ? 'Próximamente' : `Capítulo ${toRoman(next.data.numero)} →`}
            </span>
            <span class="capitulo-nav-title">{next.data.titulo}</span>
          </a>
        ) : <span />}
      </div>
    </nav>

    <NewsletterCard compact />
  </main>
  <GlosarioPin />
</BaseLayout>
