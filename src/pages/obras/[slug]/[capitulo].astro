---
// Página de un capítulo individual.
// Ruta: /obras/[slug-obra]/[numero-titulo]/
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  const obrasMap = new Map(obras.map((o) => [o.slug, o]));
  // (slug = nombre del archivo sin .md)

  // Solo capítulos publicados (no borradores)
  const capitulos = (await getCollection('capitulos', (c) => c.data.borrador !== true));

  // Agrupar por obra para calcular prev/next
  const porObra = new Map<string, typeof capitulos>();
  for (const cap of capitulos) {
    const arr = porObra.get(cap.data.obra) ?? [];
    arr.push(cap);
    porObra.set(cap.data.obra, arr);
  }
  for (const arr of porObra.values()) {
    arr.sort((a, b) => a.data.numero - b.data.numero);
  }

  const paths = [];
  for (const cap of capitulos) {
    const obra = obrasMap.get(cap.data.obra);
    if (!obra) {
      throw new Error(
        `Capítulo "${cap.id}" referencia obra "${cap.data.obra}" que no existe en src/content/obras/.`,
      );
    }
    const lista = porObra.get(cap.data.obra) ?? [];
    const idx = lista.findIndex((c) => c.id === cap.id);
    const prev = idx > 0 ? lista[idx - 1] : null;
    const next = idx < lista.length - 1 ? lista[idx + 1] : null;

    // El slug del archivo es "samantha-solstice/01-titulo"; cogemos la parte final
    const capSlug = cap.slug.split('/').pop() as string;

    paths.push({
      params: { slug: obra.slug, capitulo: capSlug },
      props: { cap, obra, prev, next },
    });
  }
  return paths;
}

const { cap, obra, prev, next } = Astro.props;
const { Content } = await cap.render();

const fechaFmt = cap.data.fecha.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const padNum = (n: number) => String(n).padStart(2, '0');

const prevSlug = prev ? prev.slug.split('/').pop() : null;
const nextSlug = next ? next.slug.split('/').pop() : null;
---

<BaseLayout
  title={`${cap.data.titulo} · ${obra.data.titulo}`}
  description={cap.data.sinopsis ?? `Capítulo ${cap.data.numero} de ${obra.data.titulo}.`}
>
  <article>
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/obras/">Obras</a>
      <span aria-hidden="true">›</span>
      <a href={`/obras/${obra.slug}/`}>{obra.data.titulo}</a>
    </nav>

    <header class="cap-header">
      <p class="meta">
        Capítulo {padNum(cap.data.numero)} · {fechaFmt}
      </p>
      <h1>{cap.data.titulo}</h1>
    </header>

    <div class="prose">
      <Content />
    </div>

    <hr />

    <nav class="cap-nav" aria-label="Navegación entre capítulos">
      <div class="nav-prev">
        {prev ? (
          <a href={`/obras/${obra.slug}/${prevSlug}/`}>
            <span class="dir">← Anterior</span>
            <span class="t">{prev.data.titulo}</span>
          </a>
        ) : <span class="disabled">— Primer capítulo —</span>}
      </div>
      <div class="nav-index">
        <a href={`/obras/${obra.slug}/`}>Índice</a>
      </div>
      <div class="nav-next">
        {next ? (
          <a href={`/obras/${obra.slug}/${nextSlug}/`}>
            <span class="dir">Siguiente →</span>
            <span class="t">{next.data.titulo}</span>
          </a>
        ) : <span class="disabled">— Último capítulo publicado —</span>}
      </div>
    </nav>
  </article>

  <NewsletterForm compact title="¿Te ha gustado el capítulo?" />
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: var(--space-md);
    text-align: center;
  }
  .breadcrumb a { color: var(--color-text-soft); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb span { margin: 0 0.4rem; }

  .cap-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .cap-header .meta {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--color-text-soft);
    margin: 0 0 0.3rem;
  }
  .cap-header h1 {
    font-size: 2.2rem;
    margin: 0;
  }

  .cap-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    max-width: var(--measure);
    margin: 0 auto;
  }
  .cap-nav a {
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
  }
  .cap-nav a:hover .t { color: var(--color-accent); }
  .cap-nav .nav-prev { text-align: left; }
  .cap-nav .nav-next { text-align: right; }
  .cap-nav .nav-index a {
    color: var(--color-text-soft);
    text-decoration: underline;
  }
  .cap-nav .dir {
    font-size: 0.8rem;
    color: var(--color-text-soft);
    margin-bottom: 0.15rem;
  }
  .cap-nav .t {
    font-family: var(--font-serif);
    font-size: 1rem;
  }
  .cap-nav .disabled {
    color: var(--color-text-soft);
    font-size: 0.85rem;
  }
  @media (max-width: 600px) {
    .cap-nav {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
    }
    .cap-nav .nav-prev,
    .cap-nav .nav-next { text-align: center; }
  }
</style>
