---
// Página índice del glosario de una obra: grid de cards 3/2/1 columnas.
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Fleuron from '../../../../components/Fleuron.astro';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((obra) => ({
    params: { slug: obra.id },
    props: { obra },
  }));
}

const { obra } = Astro.props;

const terminos = (await getCollection('glosario', (t) => t.data.obra === obra.id))
  .sort((a, b) =>
    a.data.termino.localeCompare(b.data.termino, 'es', { sensitivity: 'base' }),
  );
---

<BaseLayout
  title={`Glosario · ${obra.data.titulo}`}
  description={`Glosario de términos, personajes y lugares de ${obra.data.titulo}.`}
  active="obras"
  wide
>
  <nav class="breadcrumb" aria-label="Migas de pan">
    <a href="/">Obras</a>
    <span class="sep" aria-hidden="true">/</span>
    <a href={`/obras/${obra.id}/`}>{obra.data.titulo}</a>
  </nav>

  <header class="head">
    <p class="kicker">{obra.data.titulo}</p>
    <h1>Glosario</h1>
    <div class="orn"><Fleuron size={14} opacity={0.5} /></div>
  </header>

  {terminos.length === 0 ? (
    <p class="text-soft empty">Aún no hay términos en el glosario.</p>
  ) : (
    <ul class="terminos-grid">
      {terminos.map((t) => {
        const tSlug = t.id.split('/').pop();
        return (
          <li>
            <a
              href={`/obras/${obra.id}/glosario/${tSlug}/`}
              aria-label={`Ver entrada del glosario: ${t.data.termino}`}
            >
              <span class="termino">{t.data.termino}</span>
              <span class="desc">{t.data.descripcion_corta}</span>
              <span class="cta" aria-hidden="true">
                Ver <span class="arrow">→</span>
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: 1.25rem;
    font-family: var(--sans);
    font-size: 0.88rem;
    text-align: center;
  }
  .breadcrumb a {
    color: var(--ink-soft);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep {
    margin: 0 0.5rem;
    color: var(--ink-faint);
  }

  .head {
    text-align: center;
    margin-bottom: 2rem;
  }
  .kicker {
    font-family: var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin: 0 0 0.4rem;
  }
  .head h1 {
    font-family: var(--display);
    font-size: 2.2rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
  }
  .orn {
    color: var(--ink-faint);
    margin-top: 0.6rem;
  }
  .empty {
    text-align: center;
    margin-top: 2rem;
  }

  .terminos-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 800px) {
    .terminos-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .terminos-grid { grid-template-columns: 1fr; }
  }
  .terminos-grid a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: var(--paper);
    text-decoration: none;
    color: var(--ink);
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .terminos-grid a:hover {
    background: var(--bg-soft);
    border-color: var(--accent);
  }
  .terminos-grid a:hover .termino,
  .terminos-grid a:hover .cta {
    color: var(--accent);
  }
  .terminos-grid a:hover .arrow {
    transform: translateX(3px);
  }
  .terminos-grid .termino {
    font-family: var(--display);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.4rem;
    transition: color 120ms ease;
  }
  .terminos-grid .desc {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.45;
    flex: 1;
    margin-bottom: 0.7rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .terminos-grid .cta {
    margin-top: auto;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink-soft);
    transition: color 120ms ease;
  }
  .terminos-grid .arrow {
    display: inline-block;
    transition: transform 120ms ease;
  }
</style>
