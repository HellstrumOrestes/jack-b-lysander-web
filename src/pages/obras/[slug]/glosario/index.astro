---
// Página índice del glosario de una obra: lista todos los términos
// con su descripción corta y enlace a la página individual.
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((obra) => ({
    params: { slug: obra.id },
    props: { obra },
  }));
}

const { obra } = Astro.props;

// Términos pertenecientes a esta obra, ordenados alfabéticamente.
const terminos = (await getCollection('glosario', (t) => t.data.obra === obra.id))
  .sort((a, b) =>
    a.data.termino.localeCompare(b.data.termino, 'es', { sensitivity: 'base' }),
  );

const padNum = (n: number) => String(n).padStart(2, '0');
---

<BaseLayout
  title={`Glosario · ${obra.data.titulo}`}
  description={`Glosario de términos, personajes y lugares de ${obra.data.titulo}.`}
>
  <article>
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/obras/">Obras</a>
      <span aria-hidden="true">›</span>
      <a href={`/obras/${obra.id}/`}>{obra.data.titulo}</a>
    </nav>

    <header class="head">
      <p class="meta">Glosario</p>
      <h1>{obra.data.titulo}</h1>
    </header>

    {terminos.length === 0 ? (
      <p class="text-soft empty">Aún no hay términos en el glosario.</p>
    ) : (
      <ol class="terminos-list">
        {terminos.map((t) => {
          const tSlug = t.id.split('/').pop();
          return (
            <li>
              <a
                href={`/obras/${obra.id}/glosario/${tSlug}/`}
                aria-label={`Ver entrada del glosario: ${t.data.termino}`}
              >
                <div class="info">
                  <span class="termino">{t.data.termino}</span>
                  <span class="cap-sinopsis">{t.data.descripcion_corta}</span>
                </div>
                <span class="cta" aria-hidden="true">
                  Ver <span class="arrow">→</span>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: var(--space-md);
    text-align: center;
  }
  .breadcrumb a { color: var(--color-text-soft); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb span { margin: 0 0.4rem; }

  .head {
    text-align: center;
    margin-bottom: var(--space-md);
  }
  .meta {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--color-text-soft);
    margin: 0 0 0.3rem;
  }
  .head h1 {
    margin: 0;
    font-size: 2.2rem;
  }
  .empty {
    text-align: center;
    margin-top: var(--space-md);
  }

  .terminos-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--measure);
    margin-left: auto;
    margin-right: auto;
  }
  .terminos-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .terminos-list li:first-child {
    border-top: 1px solid var(--color-border);
  }
  .terminos-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 0.85rem 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background-color 120ms ease;
  }
  .terminos-list a:hover {
    background-color: var(--color-bg-soft);
  }
  .terminos-list a:hover .termino,
  .terminos-list a:hover .cta {
    color: var(--color-accent);
  }
  .terminos-list a:hover .arrow {
    transform: translateX(3px);
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .termino {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    transition: color 120ms ease;
  }
  .cap-sinopsis {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-text-soft);
  }
  .cta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-soft);
    white-space: nowrap;
    transition: color 120ms ease;
  }
  .arrow {
    display: inline-block;
    transition: transform 120ms ease;
  }
</style>
