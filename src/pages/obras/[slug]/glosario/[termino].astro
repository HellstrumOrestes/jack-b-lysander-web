---
// Página individual de un término del glosario.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Fleuron from '../../../../components/Fleuron.astro';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  const obrasMap = new Map(obras.map((o) => [o.id, o]));
  const terminos = await getCollection('glosario');

  const paths = [];
  for (const t of terminos) {
    const obra = obrasMap.get(t.data.obra);
    if (!obra) {
      throw new Error(
        `Término del glosario "${t.id}" referencia obra "${t.data.obra}" que no existe.`,
      );
    }
    const tSlug = t.id.split('/').pop() as string;
    paths.push({
      params: { slug: obra.id, termino: tSlug },
      props: { termino: t, obra },
    });
  }
  return paths;
}

const { termino, obra } = Astro.props;
const { Content } = await render(termino);

const terminoSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: termino.data.termino,
  description: termino.data.descripcion_corta,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: `Glosario de ${obra.data.titulo}`,
    url: new URL(`/obras/${obra.id}/glosario/`, Astro.site).toString(),
  },
  inLanguage: 'es-ES',
};
---

<BaseLayout
  title={`${termino.data.termino} · Glosario · ${obra.data.titulo}`}
  description={termino.data.descripcion_corta}
  schema={[terminoSchema]}
  active="obras"
>
  <nav class="breadcrumb" aria-label="Migas de pan">
    <a href="/">Obras</a>
    <span class="sep" aria-hidden="true">/</span>
    <a href={`/obras/${obra.id}/`}>{obra.data.titulo}</a>
    <span class="sep" aria-hidden="true">/</span>
    <a href={`/obras/${obra.id}/glosario/`}>Glosario</a>
  </nav>

  <article class="termino">
    <header class="head">
      <p class="kicker">Glosario · {obra.data.titulo}</p>
      <h1>{termino.data.termino}</h1>
      <div class="orn"><Fleuron size={14} opacity={0.5} /></div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <hr />

    <nav class="back" aria-label="Volver">
      <a href={`/obras/${obra.id}/glosario/`}>← Ver glosario completo</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: 1.25rem;
    font-family: var(--sans);
    font-size: 0.88rem;
    text-align: center;
  }
  .breadcrumb a {
    color: var(--ink-soft);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep {
    margin: 0 0.5rem;
    color: var(--ink-faint);
  }

  .head {
    text-align: center;
    margin: 1.5rem auto 2.5rem;
    max-width: var(--measure);
  }
  .kicker {
    font-family: var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.74rem;
    color: var(--ink-soft);
    margin: 0 0 0.5rem;
  }
  .head h1 {
    font-family: var(--display);
    font-size: 2.2rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }
  .orn { color: var(--ink-faint); }

  .back {
    text-align: center;
    font-family: var(--sans);
    font-size: 0.9rem;
  }
  .back a {
    color: var(--ink-soft);
    text-decoration: none;
  }
  .back a:hover { color: var(--accent); }
</style>
