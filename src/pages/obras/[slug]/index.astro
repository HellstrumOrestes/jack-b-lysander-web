---
// Página de una obra individual: sinopsis larga + índice de capítulos.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((obra) => ({
    params: { slug: obra.id },
    props: { obra },
  }));
}

const { obra } = Astro.props;
const { Content } = await render(obra);

// Cargar capítulos publicados de esta obra
const capitulos = (await getCollection('capitulos', (c) =>
  c.data.obra === obra.id && c.data.borrador !== true,
)).sort((a, b) => a.data.numero - b.data.numero);

// Términos del glosario de esta obra (orden alfabético)
const terminosGlosario = (await getCollection('glosario', (t) => t.data.obra === obra.id))
  .sort((a, b) =>
    a.data.termino.localeCompare(b.data.termino, 'es', { sensitivity: 'base' }),
  );

const fechaFmt = (d: Date) =>
  d.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });

const padNum = (n: number) => String(n).padStart(2, '0');

// JSON-LD CreativeWorkSeries: identifica la obra como una serie literaria
// con autor, idioma, género y partes (capítulos publicados).
const obraUrl = new URL(`/obras/${obra.id}/`, Astro.site).toString();
const seriesSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWorkSeries',
  name: obra.data.titulo,
  url: obraUrl,
  inLanguage: 'es-ES',
  description: obra.data.sinopsis_corta,
  genre: obra.data.genero,
  datePublished: obra.data.fecha_inicio.toISOString().split('T')[0],
  author: {
    '@type': 'Person',
    name: 'Jack B. Lysander',
    url: new URL('/sobre/', Astro.site).toString(),
  },
  hasPart: capitulos.map((c) => {
    const capSlug = c.id.split('/').pop();
    return {
      '@type': 'Chapter',
      name: c.data.titulo,
      url: new URL(`/obras/${obra.id}/${capSlug}/`, Astro.site).toString(),
      position: c.data.numero,
      datePublished: c.data.fecha.toISOString().split('T')[0],
    };
  }),
};
---

<BaseLayout
  title={obra.data.titulo}
  description={obra.data.sinopsis_corta}
  ogImage={obra.data.imagen_portada}
  schema={[seriesSchema]}
>
  <article class="obra">
    {obra.data.imagen_portada && (
      <img
        class="cover"
        src={obra.data.imagen_portada}
        alt={`Portada de ${obra.data.titulo}`}
      />
    )}
    <header class="obra-header">
      <p class="meta">
        {obra.data.genero ? `${obra.data.genero} · ` : ''}{obra.data.estado}
      </p>
      <h1>{obra.data.titulo}</h1>
    </header>

    <div class="prose sinopsis">
      <Content />
    </div>

    <section class="capitulos">
      <h2>Capítulos</h2>
      {capitulos.length === 0 ? (
        <p class="text-soft">Aún no hay capítulos publicados.</p>
      ) : (
        <ol class="capitulos-list">
          {capitulos.map((cap) => {
            const slugCap = cap.id.split('/').pop();
            return (
              <li>
                <a
                  href={`/obras/${obra.id}/${slugCap}/`}
                  aria-label={`Leer capítulo ${cap.data.numero}: ${cap.data.titulo}`}
                >
                  <span class="num">{padNum(cap.data.numero)}</span>
                  <div class="info">
                    <span class="titulo">{cap.data.titulo}</span>
                    <span class="fecha">{fechaFmt(cap.data.fecha)}</span>
                    {cap.data.sinopsis && (
                      <span class="cap-sinopsis">{cap.data.sinopsis}</span>
                    )}
                  </div>
                  <span class="cta" aria-hidden="true">
                    Leer <span class="arrow">→</span>
                  </span>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </section>

    {terminosGlosario.length > 0 && (
      <section class="glosario-section">
        <h2>Glosario</h2>
        <ol class="glosario-list">
          {terminosGlosario.map((t) => {
            const tSlug = t.id.split('/').pop();
            return (
              <li>
                <a
                  href={`/obras/${obra.id}/glosario/${tSlug}/`}
                  aria-label={`Ver entrada del glosario: ${t.data.termino}`}
                >
                  <div class="info">
                    <span class="termino">{t.data.termino}</span>
                    <span class="termino-desc">{t.data.descripcion_corta}</span>
                  </div>
                  <span class="cta" aria-hidden="true">
                    Ver <span class="arrow">→</span>
                  </span>
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    )}
  </article>

  <NewsletterForm compact />
</BaseLayout>

<style>
  .cover {
    margin: 0 auto var(--space-md);
    max-height: 360px;
    object-fit: cover;
    border-radius: 4px;
  }
  .obra-header {
    text-align: center;
    margin-bottom: var(--space-md);
  }
  .obra-header h1 {
    margin: 0.2rem 0 0;
    font-size: 2.4rem;
  }
  .meta {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    color: var(--color-text-soft);
    margin: 0;
  }
  .sinopsis {
    margin-bottom: var(--space-lg);
  }
  .capitulos {
    max-width: var(--measure);
    margin: 0 auto;
  }
  .capitulos h2 {
    font-size: 1.4rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .capitulos-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .capitulos-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .capitulos-list a {
    display: grid;
    grid-template-columns: 2.4em 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 0.85rem 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background-color 120ms ease;
  }
  .capitulos-list a:hover {
    background-color: var(--color-bg-soft);
  }
  .capitulos-list a:hover .titulo,
  .capitulos-list a:hover .cta {
    color: var(--color-accent);
  }
  .capitulos-list a:hover .arrow {
    transform: translateX(3px);
  }
  .capitulos-list .num {
    font-family: var(--font-sans);
    font-feature-settings: 'tnum';
    color: var(--color-text-soft);
    font-size: 0.9rem;
    padding-top: 0.2rem;
  }
  .capitulos-list .info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .capitulos-list .titulo {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.3;
    transition: color 120ms ease;
  }
  .capitulos-list .fecha {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-text-soft);
    letter-spacing: 0.02em;
  }
  .capitulos-list .cap-sinopsis {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-text-soft);
    margin-top: 0.15rem;
  }
  .capitulos-list .cta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-soft);
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: color 120ms ease;
  }
  .capitulos-list .arrow {
    display: inline-block;
    transition: transform 120ms ease;
  }
  @media (max-width: 520px) {
    .capitulos-list a {
      grid-template-columns: 2em 1fr;
      gap: 0.6rem;
      padding: 0.75rem 0.25rem;
    }
    .capitulos-list .cta {
      grid-column: 2;
      justify-self: end;
      margin-top: 0.4rem;
    }
  }

  /* Sección glosario en la página de obra (al final, mismo formato que capítulos) */
  .glosario-section {
    max-width: var(--measure);
    margin: var(--space-lg) auto 0;
  }
  .glosario-section h2 {
    font-size: 1.4rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .glosario-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .glosario-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .glosario-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 0.85rem 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background-color 120ms ease;
  }
  .glosario-list a:hover {
    background-color: var(--color-bg-soft);
  }
  .glosario-list a:hover .termino,
  .glosario-list a:hover .cta {
    color: var(--color-accent);
  }
  .glosario-list a:hover .arrow {
    transform: translateX(3px);
  }
  .glosario-list .info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .glosario-list .termino {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    transition: color 120ms ease;
  }
  .glosario-list .termino-desc {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-text-soft);
  }
  .glosario-list .cta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-soft);
    white-space: nowrap;
    transition: color 120ms ease;
  }
  .glosario-list .arrow {
    display: inline-block;
    transition: transform 120ms ease;
  }
  @media (max-width: 520px) {
    .glosario-list a {
      gap: 0.6rem;
      padding: 0.75rem 0.25rem;
    }
  }
</style>
