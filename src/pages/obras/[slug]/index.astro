---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Fleuron from '../../components/Fleuron.astro';
import { getCollection } from 'astro:content';
import { toRoman, estadoSlug } from '../../lib/utils';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((o) => ({ params: { slug: o.slug }, props: { obra: o } }));
}

const { obra } = Astro.props;
const allCaps = await getCollection('capitulos', (c) => c.data.obra === obra.slug);
const capitulos = allCaps.sort((a, b) => a.data.numero - b.data.numero);
---
<BaseLayout active="home" title={`${obra.data.titulo} — Jack B. Lysander`}
            description={obra.data.sinopsis_corta}>
  <main class="view view-obra">
    <nav class="breadcrumb">
      <a href="/">← Obras</a>
    </nav>

    <header class="obra-header">
      <div class="obra-cover" style={`--cover-bg:${obra.data.lomo.color};--cover-accent:${obra.data.lomo.accent};`}>
        <div class="obra-cover-inner">
          <p class="obra-cover-author">Jack B. Lysander</p>
          <hr class="obra-cover-rule" />
          <p class="obra-cover-title">{obra.data.titulo}</p>
          <div class="obra-cover-fleuron"><Fleuron size={12} opacity={0.7} /></div>
        </div>
      </div>

      <div class="obra-meta">
        <p class="obra-kicker">
          <span>{obra.data.genero}</span>
          <span class="dot">·</span>
          <span class={`estado estado-${estadoSlug(obra.data.estado)}`}>{obra.data.estado}</span>
        </p>
        <h1 class="obra-title">{obra.data.titulo}</h1>
        {(obra.data.sinopsis_larga ?? [obra.data.sinopsis_corta]).map((p) => (
          <p class="obra-syn">{p}</p>
        ))}
        <dl class="obra-stats">
          <div><dt>Inicio</dt><dd>{obra.data.fecha_inicio ?? '—'}</dd></div>
          <div><dt>Capítulos</dt><dd>{obra.data.capitulos_publicados}</dd></div>
          <div><dt>Estado</dt><dd>{obra.data.estado}</dd></div>
        </dl>
      </div>
    </header>

    <section class="capitulos-section">
      <header class="section-head section-head-left">
        <p class="section-kicker">Índice</p>
        <h2 class="section-title">Capítulos</h2>
      </header>

      {capitulos.length === 0 ? (
        <p class="text-soft">Aún no hay capítulos publicados.</p>
      ) : (
        <ol class="capitulos-list">
          {capitulos.map((c) => {
            const slugFile = c.slug.split('/').pop();
            const href = `/obras/${obra.slug}/${slugFile}/`;
            return (
              <li class={`capitulo-item ${c.data.proximo ? 'is-next' : ''}`}>
                <a class={`capitulo-link ${c.data.proximo ? 'is-disabled' : ''}`}
                   href={c.data.proximo ? '#' : href}
                   aria-disabled={c.data.proximo ? 'true' : 'false'}>
                  <span class="capitulo-num">
                    <span class="capitulo-num-pre">Capítulo</span>
                    <span class="capitulo-num-roman">{toRoman(c.data.numero)}</span>
                  </span>
                  <span class="capitulo-body">
                    <span class="capitulo-titulo">{c.data.titulo}</span>
                    <span class="capitulo-syn">{c.data.sinopsis}</span>
                    <span class="capitulo-meta">
                      {c.data.proximo ? 'Próximamente' : `${c.data.fecha} · ${c.data.minutos} min de lectura`}
                    </span>
                  </span>
                  {!c.data.proximo && <span class="capitulo-arrow" aria-hidden="true">→</span>}
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </section>
  </main>
</BaseLayout>
